# ===== Auth / Email / Google 示例配置 =====

# 是否要求邮箱验证
REQUIRE_EMAIL_VERIFICATION=true

# ===== Resend 邮件发送 =====
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxx
RESEND_FROM_EMAIL=Dialect Compare <no-reply@your-domain.com>
# 可不填，默认就是官方地址
RESEND_API_BASE=https://api.resend.com

# ===== SMTP 兜底（不想用 Resend 时再配） =====
# SMTP_HOST=smtp.example.com
# SMTP_PORT=587
# SMTP_USERNAME=your_smtp_user
# SMTP_PASSWORD=your_smtp_password
# SMTP_FROM=no-reply@your-domain.com

# ===== 前端页面地址（建议配置） =====
# 用于邮件中的验证/重置链接；没配时会回退到后端 verify 接口或直接发 token
FRONTEND_BASE_URL=https://your-frontend.example.com
FRONTEND_VERIFY_EMAIL_URL=https://your-frontend.example.com/verify-email
FRONTEND_RESET_PASSWORD_URL=https://your-frontend.example.com/reset-password

# ===== Google 登录 =====
# 前端 Google One Tap / Sign-In 使用的同一个 Web Client ID
GOOGLE_CLIENT_ID=xxxxxxxxxx-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx.apps.googleusercontent.com
# 可不填，默认官方 tokeninfo 接口
GOOGLE_TOKENINFO_URL=https://oauth2.googleapis.com/tokeninfo

# ===== 自动迁移 =====
AUTO_MIGRATE=true
MIGRATION_TIMEOUT=300
